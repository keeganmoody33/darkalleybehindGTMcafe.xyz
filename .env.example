# Canonical URL for metadata (production: https://darkalleybehindthegtmcafe.xyz)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase connection
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Ops-only: gate `/ops/scan` (Lever ingestion trigger)
OPS_SCAN_SECRET=your-long-random-secret

# Vercel Cron: `GET /api/cron/ingest` (production only). Must match Vercel env CRON_SECRET.
CRON_SECRET=another-long-random-secret
